dia = int(input("Ingresa un número del 1 al 7: "))

dias_semana = ["Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo"]

if 1 <= dia <= 7:
    # Restamos 1 porque las listas en Python empiezan a contar desde 0
    print(f"El día correspondiente es: {dias_semana[dia - 1]}")
else:
    print("Error: El número ingresado no está en el rango del 1 al 7.")
